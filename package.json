{
  "name": "angular-image-editor-workspace",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve demo",
    "build": "ng build angular-image-editor",
    "build:lib": "ng build angular-image-editor",
    "build:demo": "ng build demo",
    "watch": "ng build angular-image-editor --watch --configuration development",
    "test": "ng test",
    "test:lib": "ng test angular-image-editor --watch=false",
    "test:demo": "ng test demo --watch=false",
    "lint": "ng lint",
    "pack:lib": "npm run build:lib && cd dist/angular-image-editor && npm pack"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-server": "22.0.2",
    "@angular/router": "^22.0.0",
    "@angular/ssr": "^22.0.4",
    "@imgly/background-removal": "^1.7.0",
    "fabric": "^7.4.0",
    "heic2any": "^0.0.4",
    "jsondiffpatch": "^0.7.6",
    "jspdf": "^4.2.1",
    "onnxruntime-web": "1.21.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.5",
    "@angular/cli": "^22.0.5",
    "@angular/compiler-cli": "^22.0.5",
    "@eslint/js": "^10.0.1",
    "angular-eslint": "22.0.0",
    "eslint": "^10.6.0",
    "jsdom": "^29.1.1",
    "ng-packagr": "^22.0.1",
    "prettier": "^3.9.4",
    "typescript": "~6.0.2",
    "typescript-eslint": "8.62.1",
    "vitest": "^4.0.8"
  }
