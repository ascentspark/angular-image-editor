{
  "name": "angular-image-editor-workspace",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve demo",
    "build": "ng build angular-image-editor",
    "build:lib": "ng build angular-image-editor",
    "build:demo": "ng build demo",
    "watch": "ng build angular-image-editor --watch --configuration development",
    "test": "ng test",
    "test:lib": "ng test angular-image-editor --watch=false",
    "test:demo": "ng test demo --watch=false",
    "lint": "ng lint",
    "pack:lib": "npm run build:lib && cd dist/angular-image-editor && npm pack"
  },
  "private": true,
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "@angular/common": "^20.0.0",
    "@angular/compiler": "^20.0.0",
    "@angular/core": "^20.0.0",
    "@angular/forms": "^20.0.0",
    "@angular/platform-browser": "^20.0.0",
    "@angular/platform-server": "^20.0.0",
    "@angular/router": "^20.0.0",
    "@angular/ssr": "^20.3.30",
    "@imgly/background-removal": "^1.7.0",
    "fabric": "^7.4.0",
    "heic2any": "^0.0.4",
    "jsondiffpatch": "^0.7.6",
    "jspdf": "^4.2.1",
    "onnxruntime-web": "1.27.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^20.0.0",
    "@angular/cli": "^20.0.0",
    "@angular/compiler-cli": "^20.0.0",
    "@eslint/js": "^9.0.0",
    "angular-eslint": "^20.7.0",
    "eslint": "^9.0.0",
    "jsdom": "^28.0.0",
    "ng-packagr": "^20.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.60.1",
    "vitest": "^4.0.8"
  }
